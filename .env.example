# =============================================================================
# Scotty's Gardening Lab — Environment Variables
# =============================================================================
# Copy to .env.local and fill in your values.

# Brain (required for embedding/search scripts)
BRAIN_DB_URL=postgresql://user:pass@host:5432/dbname

# Brain model overrides (optional — defaults in template.config.ts)
# BRAIN_MODEL=intfloat/e5-base-v2
# BRAIN_SEARCH_MODE=hybrid
# BRAIN_RERANKER=cross-encoder/ms-marco-MiniLM-L-6-v2

# Analytics — Google Search Console (optional)
# GSC_KEY_PATH=~/.config/keys/gsc-service-account.json
# GSC_SITE=sc-domain:scottysgardeninglab.com

# Analytics — Google Analytics 4 (optional)
# GA4_KEY_PATH=~/.config/keys/ga4-service-account.json
# GA4_PROPERTY=properties/XXXXXXXXX

# CRM — Webhook (if crm.provider = "webhook")
# WEBHOOK_URL=https://...
