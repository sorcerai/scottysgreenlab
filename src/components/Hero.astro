---

---

<section
  class="w-full min-h-[90vh] grid grid-cols-1 md:grid-cols-2 border-b border-carbon relative"
>
  <!-- Left: Typography & Hook -->
  <div
    class="flex flex-col justify-between p-6 md:p-12 border-b md:border-b-0 md:border-r border-carbon bg-isotope relative overflow-hidden"
  >
    <div
      class="font-mono text-xs text-carbon/60 uppercase tracking-widest mb-8"
    >
      Loc: Spring Branch, TX <br />
      Est. 2026 // Lat: 29.79N
    </div>

    <div class="flex flex-col gap-4 z-10">
      <div
        class="relative z-10 text-center max-w-4xl mx-auto px-4 mt-20 md:text-left md:mx-0 md:mt-0"
      >
        <h1
          class="text-7xl md:text-9xl font-display font-black leading-[0.85] uppercase tracking-tighter"
        >
          Dirt <br />
          <span class="text-carbon/30">Is</span>
          <br />
          Dead.
        </h1>
        <h2
          class="text-3xl md:text-5xl font-display font-bold leading-none uppercase text-sprout bg-carbon inline-block px-2 self-start transform -rotate-1 mt-4"
        >
          Soil Is Alive.
        </h2>
      </div>

      <div class="mt-12 md:mt-auto">
        <p class="font-sans text-lg md:text-xl max-w-md leading-relaxed mb-8">
          We are waging war on bacteria, and we are losing. <br />
          Re-engage the <span class="bg-sprout text-carbon px-1"
            >decay cycle</span
          >. Real food, grown in living soil.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#menu"
            class="group relative px-8 py-4 bg-carbon text-sprout font-mono uppercase text-sm rounded-full overflow-hidden border border-carbon hover:text-carbon hover:bg-sprout transition-colors"
          >
            <span class="relative z-10">Get Living Food</span>
          </a>
          <a
            href="#compost"
            class="px-8 py-4 border border-carbon text-carbon font-mono uppercase text-sm rounded-full hover:bg-carbon/5 transition-colors text-center"
          >
            Join the Decay Cycle
          </a>
        </div>
      </div>

      <!-- Decorative Elements -->
      <div class="absolute bottom-0 right-0 p-4 opacity-10">
        <svg
          width="200"
          height="200"
          viewBox="0 0 100 100"
          class="animate-spin-slow"
        >
          <path
            d="M50 0 A50 50 0 1 1 50 100 A50 50 0 1 1 50 0"
            fill="currentColor"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- Right: Visual (Hands in Soil / Macro) -->
  <div
    class="relative bg-carbon flex items-center justify-center overflow-hidden group"
  >
    <div
      class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1464226184884-fa280b87c399?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center grayscale opacity-60 group-hover:grayscale-0 transition-all duration-700"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-t from-carbon via-transparent to-transparent"
    >
    </div>

    <div
      class="relative z-10 text-isotope p-8 text-center border border-isotope/20 rounded-lg backdrop-blur-sm bg-carbon/30"
    >
      <div class="font-mono text-5xl mb-2 text-sprout">4x</div>
      <div class="font-sans uppercase tracking-widest text-sm">
        Nutrient Density
      </div>
    </div>
  </div>
</section>
