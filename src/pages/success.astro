---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Sequence Initiated | Scotty's Gardening Lab">
	<Navbar />
	<main class="min-h-[80vh] flex items-center justify-center bg-carbon text-isotope relative overflow-hidden">
        <div class="absolute inset-0 bg-noise opacity-10 pointer-events-none"></div>
        
		<div class="text-center z-10 p-8">
            <div class="inline-block mb-6 p-4 rounded-full border border-sprout/20 text-sprout">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
			<h1 class="text-5xl md:text-7xl font-display font-bold uppercase mb-4">Sequence<br>Initiated</h1>
            <p class="font-sans text-xl text-isotope/60 max-w-md mx-auto mb-8">
                Your data has been logged in the network. <br/>Stand by for transmission.
            </p>
			<a href="/" class="inline-block px-8 py-4 bg-sprout text-carbon font-mono uppercase font-bold rounded-full hover:bg-white transition-colors">
				Return to Lab
			</a>
		</div>
	</main>
</Layout>
