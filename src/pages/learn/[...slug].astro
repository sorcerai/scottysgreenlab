---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import questionsData from '../../data/pseo-questions-final.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return (questionsData as any[]).map((q: any) => ({
    params: { slug: q.slug },
    props: { question: q },
  }));
}

const { question } = Astro.props;
const siteUrl = "https://scottysgardeninglab.com";
const pageUrl = `${siteUrl}/learn/${question.slug}`;

// Load the full article JSON
let article: any = null;
const articlePath = path.join(process.cwd(), 'content', 'learn', `${question.slug}.json`);
try {
  const raw = fs.readFileSync(articlePath, 'utf-8');
  article = JSON.parse(raw);
} catch {}

// Extract content string from various schema formats
function getContentString(a: any): string {
  if (!a) return '';
  // Direct string content
  if (typeof a.content === 'string') return a.content;
  // Content as object with sections
  if (a.content && typeof a.content === 'object') {
    const parts: string[] = [];
    if (a.content.opening) parts.push(a.content.opening);
    if (a.content.directAnswer) parts.push(a.content.directAnswer);
    if (Array.isArray(a.content.sections)) {
      for (const s of a.content.sections) {
        if (s.heading) parts.push(`## ${s.heading}`);
        if (s.body) parts.push(s.body);
        if (s.content) parts.push(s.content);
      }
    }
    return parts.join('\n\n');
  }
  // "body" key instead of "content"
  if (typeof a.body === 'string') return a.body;
  // "article" key
  if (typeof a.article === 'string') return a.article;
  if (a.article && typeof a.article === 'object') {
    const parts: string[] = [];
    if (a.article.opening) parts.push(a.article.opening);
    if (a.article.directAnswer) parts.push(a.article.directAnswer);
    if (Array.isArray(a.article.sections)) {
      for (const s of a.article.sections) {
        if (s.heading) parts.push(`## ${s.heading}`);
        if (s.body) parts.push(s.body);
        if (s.content) parts.push(s.content);
      }
    }
    return parts.join('\n\n');
  }
  return '';
}

// Extract sources from various locations
function getSources(a: any): any[] {
  if (!a) return [];
  if (Array.isArray(a.sources)) return a.sources;
  if (a.content?.sources && Array.isArray(a.content.sources)) return a.content.sources;
  if (a.article?.sources && Array.isArray(a.article.sources)) return a.article.sources;
  return [];
}

const contentStr = getContentString(article);
const hasArticle = contentStr.length > 200;
const title = article?.title || question.question;
const metaDesc = article?.metaDescription || article?.meta_description || article?.description || question.question;
const sources = getSources(article);

// Parse markdown into intro + sections
const sections: { heading: string; body: string }[] = [];
let directAnswer = '';
if (hasArticle) {
  const parts = contentStr.split(/^## /m);
  directAnswer = parts[0].trim();
  for (let i = 1; i < parts.length; i++) {
    const lines = parts[i].split('\n');
    const heading = lines[0].trim();
    const body = lines.slice(1).join('\n').trim();
    if (heading.toLowerCase() !== 'sources' && heading.toLowerCase() !== 'references') {
      sections.push({ heading, body });
    }
  }
}

// Pillar display names
const pillarNames: Record<string, string> = {
  'regenerative-agriculture': 'Regenerative Agriculture',
  'composting': 'Composting',
  'fermentation': 'Fermentation & Gut Health',
  'soil-science': 'Soil Science',
  'community-gardening': 'Community Gardening',
  'food-system': 'Food System',
};
const pillarName = pillarNames[question.pillar] || question.pillar;

// Render markdown paragraph to HTML (basic)
function mdToHtml(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" class="text-sprout underline hover:text-carbon transition-colors" target="_blank" rel="noopener">$1</a>');
}

// Schema
const schemaText = directAnswer.replace(/[#*_`\[\]()]/g, '').slice(0, 500);
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": question.question,
        "acceptedAnswer": { "@type": "Answer", "text": schemaText }
      }]
    },
    {
      "@type": "Article",
      "headline": title,
      "description": metaDesc,
      "url": pageUrl,
      "author": { "@type": "Organization", "name": "Scotty's Gardening Lab", "url": siteUrl },
      "publisher": { "@id": siteUrl + "/#organization" },
      "isPartOf": { "@id": siteUrl + "/#website" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["[data-speakable]", "article h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Learn", "item": siteUrl + "/learn" },
        { "@type": "ListItem", "position": 3, "name": pillarName },
        { "@type": "ListItem", "position": 4, "name": question.question }
      ]
    }
  ]
};
---

<Layout
  title={`${title} | Scotty's Gardening Lab`}
  description={metaDesc}
  url={pageUrl}
  type="article"
>
  <Navbar />

  <article class="py-16 px-4 md:px-8 bg-isotope min-h-screen">
    <div class="max-w-3xl mx-auto">

      <nav class="font-mono text-xs uppercase tracking-widest text-carbon/40 mb-8">
        <a href="/" class="hover:text-carbon transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/learn" class="hover:text-carbon transition-colors">Learn</a>
        <span class="mx-2">/</span>
        <span class="text-carbon/60">{pillarName}</span>
      </nav>

      <div class="inline-block font-mono text-xs uppercase px-3 py-1 border border-carbon rounded-full mb-6 text-carbon/60">
        {pillarName}
      </div>

      <h1 class="text-4xl md:text-5xl font-display font-bold uppercase leading-tight mb-8" data-speakable>
        {question.question}
      </h1>

      {hasArticle ? (
        <>
          <div class="bg-carbon text-isotope p-6 md:p-8 rounded-lg mb-10" data-speakable>
            <div class="font-mono text-xs uppercase text-sprout mb-3 tracking-widest">Quick Answer</div>
            <div class="font-sans text-lg md:text-xl leading-relaxed space-y-4">
              {directAnswer.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                <p set:html={mdToHtml(para)} />
              ))}
            </div>
          </div>

          {sections.map((section) => (
            <section class="mb-10">
              <h2 class="text-2xl md:text-3xl font-display font-bold uppercase mb-4">{section.heading}</h2>
              <div class="font-sans text-base md:text-lg leading-relaxed text-carbon/80 space-y-4">
                {section.body.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                  <p set:html={mdToHtml(para)} />
                ))}
              </div>
            </section>
          ))}

          {sources.length > 0 && (
            <section class="border-t border-carbon/20 pt-8 mb-10">
              <h2 class="text-xl font-display font-bold uppercase mb-4">Sources</h2>
              <ol class="list-decimal list-inside space-y-2 font-sans text-sm text-carbon/60">
                {sources.map((src: any) => (
                  <li>
                    {src.url ? (
                      <a href={src.url} class="hover:text-carbon underline transition-colors" target="_blank" rel="noopener nofollow">
                        {src.title || src.publisher || src.url}
                      </a>
                    ) : (
                      <span>{src.title || src.publisher}</span>
                    )}
                    {src.publisher && src.title && <span class="text-carbon/40"> — {src.publisher}</span>}
                  </li>
                ))}
              </ol>
            </section>
          )}
        </>
      ) : (
        <div class="font-sans text-lg leading-relaxed text-carbon/70 mb-10">
          <p>This article is being written. Check back soon.</p>
        </div>
      )}

      <div class="bg-carbon text-isotope p-6 md:p-8 rounded-lg text-center">
        <div class="font-mono text-xs uppercase text-sprout mb-3 tracking-widest">Want to learn more?</div>
        <h2 class="text-2xl font-display font-bold uppercase mb-4">Join the Decay Cycle</h2>
        <p class="font-sans text-isotope/60 mb-6 max-w-md mx-auto">
          Get notified about new harvests, fermentation batches, and composting workshops in Spring Branch, TX.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/#menu" class="px-8 py-4 bg-sprout text-carbon font-mono uppercase text-sm rounded-full hover:bg-white transition-colors font-bold">See the Market Menu</a>
          <a href="/#compost" class="px-8 py-4 border border-isotope/30 text-isotope font-mono uppercase text-sm rounded-full hover:bg-isotope/10 transition-colors">Join the Network</a>
        </div>
      </div>
    </div>
  </article>

  <footer class="bg-carbon text-isotope/40 py-12 border-t border-isotope/10">
    <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="font-mono text-xs uppercase">&copy; 2026 Scotty's Gardening Lab. All Systems Normal.</div>
      <div class="flex gap-6 font-mono text-xs uppercase">
        <a href="#" class="hover:text-sprout transition-colors">Instagram</a>
        <a href="#" class="hover:text-sprout transition-colors">Email</a>
      </div>
    </div>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
</Layout>
